# --- TriageBot · variables de entorno ---
# Copia este archivo a .env y rellena los valores.
# .env NUNCA se commitea (debe estar en .gitignore).

# Ruta de la base de datos SQLite (formato sqlite:///...).
# Por defecto: sqlite:///./triagebot.db
DATABASE_URL=sqlite:///./triagebot.db

# Backend del clasificador: openrouter | local | anthropic
LLM_PROVIDER=openrouter

# --- OpenAI-compatible (openrouter / local) ---
# Endpoint OpenAI-compatible. OpenRouter: https://openrouter.ai/api/v1
# Local (Ollama/vLLM/LM Studio): p. ej. http://localhost:11434/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# API key de OpenRouter (https://openrouter.ai/keys). En local suele valer cualquiera.
# Alternativa aceptada por el código: OPENAI_API_KEY (útil para servidores locales).
OPENROUTER_API_KEY=
# Modelo en el backend OpenAI-compatible.
LLM_MODEL=google/gemini-3.1-flash-lite

# --- Anthropic (solo si LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8

# --- Clasificación: enums y límites (opcionales, tienen defaults) ---
# Categorías válidas separadas por coma. Añade nuevas aquí sin tocar código.
# TICKET_CATEGORIES=bug,feature_request,question,urgent
# Prioridades válidas separadas por coma (de mayor a menor).
# TICKET_PRIORITIES=P1,P2,P3
# Estados válidos del ticket.
# TICKET_STATUSES=open,in_progress,closed
# Límites de tags por ticket.
# MAX_TAGS=5
# MAX_TAG_LEN=30
# Clasificación fallback si el LLM falla.
# FALLBACK_CATEGORY=question
# FALLBACK_PRIORITY=P3
